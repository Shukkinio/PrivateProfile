generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String?
  discordId String?  @unique
  avatar    String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile  Profile?
  tracks   Track[]
  links    Link[]
  uploads  Upload[]
  sessions Session[]
  badges   UserBadge[]
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  displayName String?
  bio       String?
  location  String?
  timezone  String?
  layoutType String  @default("centered-card")
  theme     String   @default("neon-void")
  usernameEffect String @default("gradient")
  bioEffect String   @default("fade-in")
  introEnabled Boolean @default(true)
  introText String?
  customCursor Boolean @default(false)
  cursorImage String?
  discordPresence Boolean @default(true)
  musicWidget Boolean @default(false)
  bgVideoUrl String?
  bgEffects  String   @default("[]")
  effectIntensity Int  @default(50)
  blurAmount Int      @default(0)
  brightness Int      @default(100)
  saturation Int      @default(100)
  glowIntensity Int   @default(50)
  seoTitle   String?
  seoDesc    String?
  seoKeywords String?
  seoImage   String?
  favicon    String?
  embedColor String   @default("#c4b5fd")
  animatedTitle Boolean @default(false)
  accentColor String @default("#c4b5fd")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  views View[]
  analyticsEvents AnalyticsEvent[]
}

model Track {
  id       String @id @default(cuid())
  userId   String
  title    String
  artist   String?
  url      String
  duration Int?
  order    Int    @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Link {
  id       String @id @default(cuid())
  userId   String
  platform String
  url      String
  label    String
  hidden   Boolean @default(false)
  order    Int     @default(0)
  clicks   Int     @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Upload {
  id         String   @id @default(cuid())
  userId     String
  type       String
  mimeType   String
  size       Int
  url        String
  cdnUrl     String?
  public     Boolean  @default(true)
  expiresAt  DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model View {
  id        String   @id @default(cuid())
  profileId String
  ipHash    String
  fingerprint String?
  userAgent String?
  country   String?
  createdAt DateTime @default(now())
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, ipHash, createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  profileId String
  type      String
  metadata  String?
  createdAt DateTime @default(now())
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, type, createdAt])
}

model Badge {
  id        String      @id @default(cuid())
  name      String      @unique
  label     String
  icon      String?
  color     String      @default("#c4b5fd")
  type      String      @default("exclusive")
  createdAt DateTime    @default(now())
  userBadges UserBadge[]
}

model UserBadge {
  id      String @id @default(cuid())
  userId  String
  badgeId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}
